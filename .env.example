# Copy to .env.local (gitignored) for local `expo start`. EAS Build injects env per profile — see docs/MOBILE_RELEASE.md.

# Required for release/production store builds (validated at startup when EXPO_PUBLIC_APP_ENV=production).
# EXPO_PUBLIC_API_BASE_URL=https://api.example.com

# Optional: development | preview | production (EAS preview/production profiles set this automatically).
# EXPO_PUBLIC_APP_ENV=development

# Optional API client overrides (see src/api/client.ts).
# EXPO_PUBLIC_API_TIMEOUT_MS=25000
# EXPO_PUBLIC_API_BEARER=
